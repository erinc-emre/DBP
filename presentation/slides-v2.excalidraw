    {
      "id": "pvL596mqTkb8V9zDRJTH",
      "type": "text",
      "x": 60,
      "y": 1345,
      "width": 1160,
      "height": 75,
      "text": "Blender add-on that turns one real historical commercial flight + historical weather into\na cinematic 3D scene: procedural Earth, real waypoint-driven aircraft, composite weather,\nchase camera, final rendered video.",
      "fontSize": 18,
