    {
      "id": "Be3mzpTUMck6b_4X8NNA",
      "type": "text",
      "x": 60,
      "y": 4205,
      "width": 1160,
      "height": 100,
      "text": "• Scientific NetCDF stays OUT of Blender — handled in external Python; Blender consumes JSON + PNG\n• Bundle one sample flight so demo always works without API credits\n• Aircraft model is imported, not modeled from scratch\n• Spherical lat/lon → 3D is a closed-form formula, no GIS dependency",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 15,
      "containerId": null,
      "originalText": "• Scientific NetCDF stays OUT of Blender — handled in external Python; Blender consumes JSON + PNG\n• Bundle one sample flight so demo always works without API credits\n• Aircraft model is imported, not modeled from scratch\n• Spherical lat/lon → 3D is a closed-form formula, no GIS dependency",
      "lineHeight": 1.25,
      "autoResize": true,
      "strokeColor": "#1e1e1e",
      "frameId": "6ikhdDTp1qxRqJRdylmj",
