    {
      "id": "eO0orNKiGdDLbWbbwY2R",
      "type": "text",
      "x": 60,
      "y": 2035,
      "width": 557.5855712890625,
      "height": 157.5,
      "text": "• BlenderGIS — GIS / DEM / OSM (no flights or weather)\n• Blosm — OSM, terrain, GPX import\n• BlenderNC — NetCDF/GRIB scientific viz (no aviation)\n• Tacview Flight Path Importer — military/sim CSV only\n• GPX-Importer — generic GPS routes\n• Motion Path Pro — path debugging utility\n• Maps Models Importer — Google Earth scrape (legally fragile)",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 15,
      "containerId": null,
      "originalText": "• BlenderGIS — GIS / DEM / OSM (no flights or weather)\n• Blosm — OSM, terrain, GPX import\n• BlenderNC — NetCDF/GRIB scientific viz (no aviation)\n• Tacview Flight Path Importer — military/sim CSV only\n• GPX-Importer — generic GPS routes\n• Motion Path Pro — path debugging utility\n• Maps Models Importer — Google Earth scrape (legally fragile)",
      "lineHeight": 1.25,
      "autoResize": true,
      "strokeColor": "#1e1e1e",
      "frameId": "Qp9SCTip_vsqRo1KSOXC",
      "angle": 0,
