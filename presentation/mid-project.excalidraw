    {
      "id": "vj8yiAEuwjJPhTrL93tS",
      "type": "text",
      "x": 70,
      "y": 1989.775030202457,
      "width": 455.1446533203125,
      "height": 261.25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": "eWAjBkV6veHLNVgQaLu5",
